{
  "name": "@cpjet64/webai-server",
  "version": "1.5.1-dev.3",
  "description": "WebAI server for capturing and managing browser events, logs, and screenshots",
  "type": "module",
  "main": "dist/browser-connector.js",
  "bin": {
    "webai-server": "./dist/browser-connector.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/browser-connector.js",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:unit": "jest --testPathPattern=tests/.*\\.test\\.ts",
    "test:integration": "jest --testPathPattern=tests/integration"
  },
  "keywords": [
    "webai",
    "browser",
    "automation",
    "debugging",
    "logging",
    "screenshots",
    "chrome",
    "extension"
  ],
  "author": "AgentDesk AI",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lighthouse": "^12.8.2",
    "llm-cost": "^1.0.5",
    "node-fetch": "^3.3.2",
    "puppeteer-core": "^24.22.3",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "chrome-launcher": "^1.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.8",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.3.3",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jsdom": "^26.1.0",
    "nock": "^14.0.5",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.2"
  }
}
