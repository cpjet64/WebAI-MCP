{
  "name": "webai-mcp-workspace",
  "version": "1.4.3",
  "private": true,
  "description": "WebAI-MCP workspace for automated changelog and release management",
  "scripts": {
    "changelog": "auto-changelog --config .auto-changelog",
    "changelog:update": "auto-changelog --config .auto-changelog --unreleased",
    "version:bump": "npm run changelog && git add CHANGELOG.md",
    "diagnose": "node scripts/diagnose.js",
    "setup": "node scripts/setup.js",
    "setup:verbose": "node scripts/setup.js --verbose",
    "setup:quick": "node scripts/setup.js --skip-diagnostics",
    "platform-setup": "node scripts/platform-setup.js",
    "validate": "node scripts/validate-installation.js",
    "full-setup": "npm run setup && npm run platform-setup && npm run validate",
    "build": "npm run build --workspace=webai-mcp && npm run build --workspace=webai-server",
    "test": "node scripts/ci/smoke-test.js",
    "ci": "powershell -ExecutionPolicy Bypass -File ./scripts/ci.ps1",
    "ci:ps1": "powershell -ExecutionPolicy Bypass -File ./scripts/ci.ps1",
    "ci:sh": "bash ./scripts/ci.sh",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-hooks.ps1",
    "hooks:install:ps1": "powershell -ExecutionPolicy Bypass -File ./scripts/install-hooks.ps1",
    "hooks:install:sh": "bash ./scripts/install-hooks.sh",
    "validate:docs": "node scripts/ci/docs-check.js",
    "dev": "concurrently \"npm run start --workspace=webai-server\" \"npm run start --workspace=webai-mcp\"",
    "clean": "npm run clean --workspace=webai-mcp && npm run clean --workspace=webai-server"
  },
  "workspaces": [
    "webai-mcp",
    "webai-server"
  ],
  "devDependencies": {
    "auto-changelog": "^2.4.0",
    "concurrently": "^8.2.2",
    "conventional-changelog-cli": "^4.1.0",
    "conventional-changelog-conventionalcommits": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cpjet64/WebAI-MCP.git"
  },
  "keywords": [
    "mcp",
    "browser-automation",
    "chrome-extension",
    "ai-tools",
    "webai"
  ],
  "author": "cpjet64",
  "license": "MIT",
  "auto-changelog": {
    "output": "CHANGELOG.md",
    "template": "keepachangelog",
    "unreleased": true,
    "commitLimit": false,
    "backfillLimit": false,
    "handlebarsHelpers": {
      "formatCommitType": "function(type) { const types = { feat: '✨ Added', fix: '🐛 Fixed', docs: '📚 Documentation', style: '💄 Style', refactor: '♻️ Refactor', perf: '⚡ Performance', test: '✅ Tests', chore: '🔧 Chore', ci: '👷 CI/CD', build: '📦 Build' }; return types[type] || '🔄 Changed'; }"
    }
  }
}
